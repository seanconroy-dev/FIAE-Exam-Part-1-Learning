---
import Base from '../../layouts/Base.astro';
import { getAllCards, getAllModules } from '../../lib/cards';

const cards = getAllCards();
const modules = getAllModules();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Pass card data to client-side JS
const cardData = cards.map(c => ({
  id: c.id,
  slug: c.slug,
  title: c.title,
  module: c.module,
  tags: c.tags,
  question: c.card.question,
  image: c.card.image ?? null,
  answer: c.card.answer,
  answerImage: c.card.answerImage ?? null,
  examples: c.card.examples ?? [],
  type: c.card.type,
}));
---
<Base title="Quiz – FIAE Exam 1">
  <div class="max-w-2xl lg:max-w-4xl mx-auto space-y-6">
    <div class="flex items-center gap-3">
      <h1 class="text-3xl font-bold text-gray-900 shrink-0">Quiz</h1>
      <select id="quiz-module" class="flex-1 min-w-0 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        <option value="">Alle Module</option>
        {modules.map(m => <option value={m}>{m}</option>)}
      </select>
      <button id="btn-start" class="shrink-0 bg-blue-600 hover:bg-blue-700 text-white font-semibold px-4 py-2 rounded-lg text-sm transition-colors">
        Starten
      </button>
    </div>

    <!-- Progress bar -->
    <div id="progress-wrap" class="hidden">
      <div class="flex justify-between text-xs text-gray-500 mb-1">
        <span id="progress-text">Karte 1 von 0</span>
        <span id="score-text">✅ 0 · ❌ 0</span>
      </div>
      <div class="h-2 bg-gray-200 rounded-full overflow-hidden">
        <div id="progress-bar" class="h-full bg-blue-500 transition-all duration-300" style="width:0%"></div>
      </div>
    </div>

    <!-- Flashcard -->
    <div id="card-wrap" class="hidden">
      <div
        id="flip-card"
        class="relative cursor-pointer"
        style="perspective: 1000px; height: clamp(340px, 55vh, 700px);"
        title="Klicken zum Aufdecken"
      >
        <div
          id="card-inner"
          class="relative w-full transition-transform duration-400"
          style="transform-style: preserve-3d; height: 100%;"
        >
          <!-- Front -->
          <div
            class="absolute inset-0 bg-white border-2 border-blue-200 rounded-2xl p-4 md:p-8 flex flex-col shadow-md overflow-y-auto"
            style="backface-visibility: hidden;"
          >
            <div class="text-xs uppercase tracking-wider text-blue-500 font-semibold text-center">Frage</div>
            <div class="flex-1 min-h-0 flex flex-col items-center justify-center text-center">
              <div id="card-question" class="text-base sm:text-lg lg:text-2xl font-semibold text-gray-800 leading-relaxed w-full text-left"></div>
              <img id="card-image" class="hidden mt-4 max-h-32 mx-auto rounded-lg object-contain" alt="" />
            </div>
            <div class="text-center text-sm text-blue-300">Klicken zum Aufdecken →</div>
          </div>
          <!-- Back -->
          <div
            class="absolute inset-0 bg-white border-2 border-green-200 rounded-2xl p-4 md:p-8 flex flex-col shadow-md overflow-y-auto"
            style="backface-visibility: hidden; transform: rotateY(180deg);"
          >
            <div class="text-xs uppercase tracking-wider text-green-500 font-semibold text-center">Antwort</div>
            <div class="flex-1 min-h-0 flex flex-col items-center justify-center text-center">
              <div id="card-answer" class="text-base sm:text-lg lg:text-2xl text-gray-800 leading-relaxed w-full text-left"></div>
              <img id="card-answer-image" class="hidden mt-4 max-h-32 mx-auto rounded-lg object-contain" alt="" />
              <div id="card-examples" class="mt-4 hidden w-full text-left">
                <div class="text-xs uppercase tracking-wider text-gray-600 font-semibold mb-2">Beispiele</div>
                <ul id="card-examples-list" class="text-base text-gray-600 space-y-1 list-disc list-inside"></ul>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Rating buttons (shown after flip) -->
      <div id="rating-buttons" class="hidden flex gap-3 mt-4">
        <button id="btn-wrong" class="flex-1 bg-red-100 hover:bg-red-200 text-red-700 font-semibold py-3 rounded-xl text-sm transition-colors border border-red-200">
          ❌ Nochmal
        </button>
        <button id="btn-correct" class="flex-1 bg-green-100 hover:bg-green-200 text-green-700 font-semibold py-3 rounded-xl text-sm transition-colors border border-green-200">
          ✅ Gewusst
        </button>
      </div>
    </div>

    <!-- Finished screen -->
    <div id="finish-wrap" class="hidden text-center space-y-4 py-10">
      <div class="text-6xl">🎉</div>
      <h2 class="text-2xl font-bold text-gray-900">Runde abgeschlossen!</h2>
      <p id="finish-score" class="text-gray-600"></p>
      <div class="flex justify-center gap-3 mt-4">
        <button id="btn-retry-wrong" class="bg-red-100 hover:bg-red-200 text-red-700 font-semibold px-5 py-2.5 rounded-xl text-sm transition-colors border border-red-200">
          Falsche wiederholen
        </button>
        <button id="btn-restart" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-5 py-2.5 rounded-xl text-sm transition-colors">
          Neu starten
        </button>
      </div>
    </div>

    <!-- Empty state -->
    <div id="empty-state" class="text-center text-gray-400 py-16">
      Wähle ein Modul und starte das Quiz.
    </div>
  </div>
</Base>

<script define:vars={{ cardData, base }}>
  // Simple markdown bold/italic renderer for answer text
  function renderMd(text) {
    return text
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      .replace(/\*(.+?)\*/g, '<em>$1</em>')
      .replace(/`(.+?)`/g, '<code class="bg-gray-100 text-red-600 rounded px-1 text-xs">$1</code>')
      .split('\n')
      .map(line => {
        if (line.startsWith('- ')) return `<li class="ml-4 list-disc">${line.slice(2)}</li>`;
        if (line.startsWith('**') && line.endsWith('**')) return `<strong>${line.slice(2, -2)}</strong>`;
        return line;
      })
      .join('\n')
      .replace(/(<li.*<\/li>\n?)+/g, m => `<ul class="space-y-1 list-disc list-inside">${m}</ul>`);
  }

  let queue = [];
  let wrong = [];
  let current = 0;
  let score = { correct: 0, wrong: 0 };
  let flipped = false;

  const quizModule = document.getElementById('quiz-module');
  const btnStart = document.getElementById('btn-start');
  const progressWrap = document.getElementById('progress-wrap');
  const progressText = document.getElementById('progress-text');
  const scoreText = document.getElementById('score-text');
  const progressBar = document.getElementById('progress-bar');
  const cardWrap = document.getElementById('card-wrap');
  const flipCard = document.getElementById('flip-card');
  const cardInner = document.getElementById('card-inner');
  const cardQuestion = document.getElementById('card-question');
  const cardImage = document.getElementById('card-image');
  const cardAnswer = document.getElementById('card-answer');
  const cardAnswerImage = document.getElementById('card-answer-image');
  const cardExamples = document.getElementById('card-examples');
  const cardExamplesList = document.getElementById('card-examples-list');
  const ratingButtons = document.getElementById('rating-buttons');
  const btnWrong = document.getElementById('btn-wrong');
  const btnCorrect = document.getElementById('btn-correct');
  const finishWrap = document.getElementById('finish-wrap');
  const finishScore = document.getElementById('finish-score');
  const btnRetryWrong = document.getElementById('btn-retry-wrong');
  const btnRestart = document.getElementById('btn-restart');
  const emptyState = document.getElementById('empty-state');

  // Pre-fill module from URL param
  const urlParams = new URLSearchParams(window.location.search);
  const urlModule = urlParams.get('module');
  if (urlModule) {
    const opt = Array.from(quizModule.options).find(o => o.value === urlModule);
    if (opt) opt.selected = true;
  }

  function shuffle(arr) {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  function startQuiz(cards) {
    queue = shuffle(cards);
    wrong = [];
    current = 0;
    score = { correct: 0, wrong: 0 };
    emptyState.classList.add('hidden');
    finishWrap.classList.add('hidden');
    progressWrap.classList.remove('hidden');
    cardWrap.classList.remove('hidden');
    showCard();
  }

  function showCard() {
    if (current >= queue.length) {
      endRound();
      return;
    }
    const card = queue[current];
    flipped = false;
    cardInner.style.transform = '';
    ratingButtons.classList.add('hidden');
    cardQuestion.textContent = card.question;
    if (card.image) {
      cardImage.src = `${base}/${card.image}`;
      cardImage.alt = card.question;
      cardImage.classList.remove('hidden');
    } else {
      cardImage.src = '';
      cardImage.classList.add('hidden');
    }
    cardAnswer.innerHTML = renderMd(card.answer);
    if (card.answerImage) {
      cardAnswerImage.src = `${base}/${card.answerImage}`;
      cardAnswerImage.alt = card.answer;
      cardAnswerImage.classList.remove('hidden');
    } else {
      cardAnswerImage.src = '';
      cardAnswerImage.classList.add('hidden');
    }

    if (card.examples && card.examples.length > 0) {
      cardExamplesList.innerHTML = card.examples.map(e => `<li>${e}</li>`).join('');
      cardExamples.classList.remove('hidden');
    } else {
      cardExamples.classList.add('hidden');
    }

    const pct = Math.round((current / queue.length) * 100);
    progressBar.style.width = pct + '%';
    progressText.textContent = `Karte ${current + 1} von ${queue.length}`;
    scoreText.textContent = `✅ ${score.correct} · ❌ ${score.wrong}`;
  }

  function endRound() {
    cardWrap.classList.add('hidden');
    progressWrap.classList.add('hidden');
    finishWrap.classList.remove('hidden');
    const total = score.correct + score.wrong;
    const pct = total > 0 ? Math.round((score.correct / total) * 100) : 0;
    finishScore.textContent = `${score.correct} von ${total} richtig (${pct}%)`;
    btnRetryWrong.disabled = wrong.length === 0;
    btnRetryWrong.classList.toggle('opacity-40', wrong.length === 0);
  }

  flipCard.addEventListener('click', () => {
    if (!flipped) {
      flipped = true;
      cardInner.style.transform = 'rotateY(180deg)';
      ratingButtons.classList.remove('hidden');
    }
  });

  btnCorrect.addEventListener('click', () => {
    score.correct++;
    current++;
    showCard();
  });

  btnWrong.addEventListener('click', () => {
    score.wrong++;
    wrong.push(queue[current]);
    current++;
    showCard();
  });

  btnStart.addEventListener('click', () => {
    const mod = quizModule.value;
    const filtered = mod ? cardData.filter(c => c.module === mod) : cardData;
    if (filtered.length === 0) {
      alert('Keine Karten für dieses Modul gefunden.');
      return;
    }
    startQuiz(filtered);
  });

  btnRetryWrong.addEventListener('click', () => startQuiz(wrong));
  btnRestart.addEventListener('click', () => {
    const mod = quizModule.value;
    const filtered = mod ? cardData.filter(c => c.module === mod) : cardData;
    startQuiz(filtered);
  });

  // Auto-start if module is pre-selected from URL
  if (urlModule) btnStart.click();
</script>
