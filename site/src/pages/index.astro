---
import Base from '../layouts/Base.astro';
import { getAllCards, getAllModules, getCardsByModule, moduleSlug } from '../lib/cards';

const cards = getAllCards();
const modules = getAllModules();
const published = cards.filter(c => c.status === 'published').length;

const moduleColors = [
  'bg-blue-50 border-blue-200 hover:bg-blue-100',
  'bg-purple-50 border-purple-200 hover:bg-purple-100',
  'bg-green-50 border-green-200 hover:bg-green-100',
  'bg-yellow-50 border-yellow-200 hover:bg-yellow-100',
  'bg-red-50 border-red-200 hover:bg-red-100',
  'bg-indigo-50 border-indigo-200 hover:bg-indigo-100',
  'bg-pink-50 border-pink-200 hover:bg-pink-100',
];

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Base title="AP1 Lernkarten – Startseite">
  <div class="space-y-10">
    <!-- Hero -->
    <section class="text-center py-10">
      <h1 class="text-4xl font-extrabold text-gray-900 mb-3">AP1 Lernkarten</h1>
      <p class="text-lg text-gray-600 max-w-xl mx-auto">
        Strukturierte Lernkarten für die Abschlussprüfung Teil 1 der IT-Berufe.
      </p>
      <div class="flex justify-center gap-8 mt-6">
        <div class="text-center">
          <div class="text-3xl font-bold text-blue-700">{cards.length}</div>
          <div class="text-sm text-gray-500">Karten gesamt</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-green-600">{published}</div>
          <div class="text-sm text-gray-500">Veröffentlicht</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-purple-600">{modules.length}</div>
          <div class="text-sm text-gray-500">Module</div>
        </div>
      </div>
      <div class="flex justify-center gap-4 mt-8">
        <a href={`${base}/quiz`} class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-3 rounded-xl transition-colors shadow">
          Quiz starten
        </a>
        <a href={`${base}/cards`} class="bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 font-semibold px-6 py-3 rounded-xl transition-colors shadow-sm">
          Alle Karten
        </a>
      </div>
    </section>

    <!-- Modules grid -->
    <section>
      <h2 class="text-2xl font-bold text-gray-800 mb-5">Module</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {modules.map((mod, i) => {
          const count = getCardsByModule(mod).length;
          const colorClass = moduleColors[i % moduleColors.length];
          return (
            <a
              href={`${base}/modules/${moduleSlug(mod)}`}
              class={`border rounded-xl p-5 transition-colors cursor-pointer ${colorClass}`}
            >
              <div class="font-semibold text-gray-800 text-sm leading-snug mb-2">{mod}</div>
              <div class="text-2xl font-bold text-gray-700">{count}</div>
              <div class="text-xs text-gray-500">Karten</div>
            </a>
          );
        })}
      </div>
    </section>
  </div>
</Base>
